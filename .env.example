VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_TMDB_API_KEY is NO LONGER used by the app. All TMDB traffic goes through
# the authenticated `tmdb-proxy` + `suggestions` edge functions, which inject the
# key server-side. Set the key as the `TMDB_API_KEY` FUNCTION secret instead
# (Supabase → Edge Functions → Secrets), never as a VITE_ client env var.
# Google OAuth note:
# Add callback URLs in Supabase Auth settings, e.g.
# http://localhost:5173/auth/callback and https://your-domain.com/auth/callback
# Optional: set to your FastAPI backend URL to route search through the backend
# If not set, search falls back to calling TMDB directly from the browser
VITE_API_URL=https://your-api.example.com
