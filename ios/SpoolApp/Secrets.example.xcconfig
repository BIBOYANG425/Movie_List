// Copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored — your keys never get committed.
//
// After editing, rebuild in Xcode or via:
//   xcodebuild -project SpoolApp.xcodeproj -scheme SpoolApp \
//     -destination 'platform=iOS Simulator,name=iPhone 17 Pro' build
//
// Note: in .xcconfig, `//` starts a comment — so URLs with `//` must be
// escaped as `/$()/`. That's why the URL below uses `https:/$()/` — do the
// same in your real Secrets.xcconfig.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = paste-your-anon-public-key-here
TMDB_API_KEY = paste-your-tmdb-v3-key-here
